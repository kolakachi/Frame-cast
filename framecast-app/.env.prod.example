# Docker Compose build-time and runtime variables
# Copy this to .env on the server and fill in real values

# Your domain (used for VITE_API_URL and Nginx)
APP_URL=https://yourdomain.com

# Must match REVERB_APP_KEY in api/.env
REVERB_APP_KEY=your-reverb-app-key
REVERB_HOST=yourdomain.com
REVERB_PORT=443
REVERB_SCHEME=https

# Must match DB_* in api/.env
DB_DATABASE=framecast
DB_USERNAME=framecast
DB_PASSWORD=change-me-strong-password
