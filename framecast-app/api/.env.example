APP_NAME=Framecast
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=framecast
DB_USERNAME=framecast
DB_PASSWORD=framecast

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=framecast

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@framecast.test"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=framecast
REVERB_APP_KEY=framecast-app-key
REVERB_APP_SECRET=framecast-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

JWT_SECRET=change-me
JWT_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

B2_KEY=
B2_SECRET=
B2_REGION=us-east-005
B2_BUCKET=
B2_ENDPOINT=

AWS_ACCESS_KEY_ID="${B2_KEY}"
AWS_SECRET_ACCESS_KEY="${B2_SECRET}"
AWS_DEFAULT_REGION="${B2_REGION}"
AWS_BUCKET="${B2_BUCKET}"
AWS_ENDPOINT="${B2_ENDPOINT}"
AWS_USE_PATH_STYLE_ENDPOINT=true

OPENAI_API_KEY=

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
